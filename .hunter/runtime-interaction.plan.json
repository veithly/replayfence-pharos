{
  "$schema": "runtime-interaction-plan.v1",
  "base_url": "http://127.0.0.1:4387",
  "report_path": ".hunter/runtime-interaction.report.json",
  "artifact_dir": ".hunter/runtime-artifacts",
  "browsers": ["chromium", "firefox", "webkit"],
  "devices": [
    {
      "name": "mobile-chromium",
      "browser": "chromium",
      "viewport": { "width": 393, "height": 852 }
    }
  ],
  "cases": [
    {
      "name": "fresh visitor replay proof persists to history",
      "context": "fresh-history",
      "steps": [
        { "action": "goto", "path": "/" },
        { "action": "click", "testid": "guest-start-button" },
        { "action": "click", "testid": "fence-run-button" },
        { "action": "click", "testid": "replay-same-action-button" },
        { "action": "waitFor", "testid": "latch-status-badge" },
        { "action": "reload" },
        { "action": "assertText", "text": "REPLAY_REJECTED" },
        { "action": "click", "text": "Inspect saved capsule" },
        { "action": "assertVisible", "testid": "capsule-history-list" }
      ]
    },
    {
      "name": "second context verifies exported Pharos report",
      "context": "second-context-verify",
      "steps": [
        { "action": "goto", "path": "/verify" },
        { "action": "click", "role": "button", "name": "Load Pharos report", "exact": true },
        { "action": "click", "testid": "verify-capsule-button" },
        { "action": "assertText", "text": "Pharos consume report verification" },
        { "action": "assertText", "text": "decoded custom error" }
      ]
    }
  ]
}
