{
  "name": "replayfence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "replayfence:demo": "node skills/replayfence/scripts/replayfence.mjs demo --reset --out demo/replayfence-capsule.json",
    "replayfence:verify": "node skills/replayfence/scripts/replayfence.mjs verify --capsule demo/replayfence-capsule.json",
    "replayfence:showcase": "node skills/replayfence/scripts/replayfence.mjs demo --reset --format pretty --out demo/replayfence-capsule.json --transcript demo/openclaw-skill-showcase.out --json-out demo/replayfence-demo-output.json --pharos-report demo/pharos-consume-report.json",
    "contract:compile": "node scripts/compile-contract.mjs",
    "contract:deploy:pharos": "node scripts/deploy-pharos.mjs",
    "contract:consume:pharos": "node scripts/pharos-consume-demo.mjs"
  },
  "dependencies": {
    "dotenv": "latest",
    "solc": "latest",
    "viem": "latest",
    "zod": "latest"
  },
  "overrides": {
    "tmp": "^0.2.6"
  },
  "devDependencies": {}
}
